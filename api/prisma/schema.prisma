generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id              String               @id @default(uuid())
  firebaseUid     String               @unique @map("firebase_uid")
  email           String               @unique
  displayName     String?              @map("display_name")
  language        Language             @default(is)
  currency        String               @default("kr")
  role            Role                 @default(USER)
  accountType          AccountType          @default(PERSONAL) @map("account_type")
  emailNotifications   Boolean              @default(true) @map("email_notifications")
  expoPushToken        String?              @map("expo_push_token")
  suspendedAt          DateTime?            @map("suspended_at")
  createdAt            DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  vehicles        Vehicle[]
  orgMemberships  OrganizationMember[]
  techWorkOrders  WorkOrder[]          @relation("TechnicianWorkOrders")
  driverTripLogs  TripLog[]            @relation("DriverTripLogs")
  auditLogs       AuditLog[]

  @@map("users")
}

enum Language {
  is
  en
}

enum Role {
  USER
  ADMIN
}

model Vehicle {
  id             String          @id @default(uuid())
  userId         String?
  user           User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?         @map("organization_id")
  organization   Organization?   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  make           String
  model          String
  year           Int
  licensePlate   String          @unique
  vin            String?         @unique
  color          String?
  fuelType       FuelType        @default(PETROL)
  acquiredAt     DateTime?       @map("acquired_at")
  disposedAt     DateTime?       @map("disposed_at")
  archivedAt     DateTime?       @map("archived_at")
  deletedAt      DateTime?       @map("deleted_at")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  serviceRecords ServiceRecord[]
  mileageLogs    MileageLog[]
  expenses       Expense[]
  reminders      Reminder[]
  documents      Document[]
  workOrders     WorkOrder[]
  tripLogs       TripLog[]
  transfers      VehicleTransfer[]
}

model VehicleTransfer {
  id             String                @id @default(uuid())
  vehicleId      String                @map("vehicle_id")
  vehicle        Vehicle               @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  fromUserId     String?               @map("from_user_id")
  fromOrgId      String?               @map("from_org_id")
  toUserId       String?               @map("to_user_id")
  toOrgId        String?               @map("to_org_id")
  toEmail        String?               @map("to_email")
  status         VehicleTransferStatus @default(PENDING)
  tokenHash      String                @unique @map("token_hash")
  expiresAt      DateTime              @map("expires_at")
  acceptedAt     DateTime?             @map("accepted_at")
  declinedAt     DateTime?             @map("declined_at")
  createdAt      DateTime              @default(now()) @map("created_at")

  @@map("vehicle_transfers")
}

enum VehicleTransferStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

model ServiceRecord {
  id          String        @id @default(uuid())
  vehicleId   String
  vehicle     Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  types       ServiceType[] @default([])
  customType  String?       @map("custom_type")
  mileage     Int
  date        DateTime
  description String?
  cost        Decimal?      @db.Decimal(10, 2)
  shop        String?
  deletedAt   DateTime?     @map("deleted_at")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime    @updatedAt
  documents   Document[]
}

model MileageLog {
  id        String    @id @default(uuid())
  vehicleId String
  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  mileage   Int
  date      DateTime
  note      String?
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now())
}

model Expense {
  id           String          @id @default(uuid())
  vehicleId    String
  vehicle      Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  category     ExpenseCategory
  amount       Decimal         @db.Decimal(10, 2)
  date         DateTime
  description  String?
  litres           Decimal?        @db.Decimal(8, 2)
  customCategory   String?         @map("custom_category")
  recurringMonths  Int?            @map("recurring_months")
  costCenterId String?         @map("cost_center_id")
  costCenter   CostCenter?     @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  deletedAt    DateTime?       @map("deleted_at")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  documents    Document[]
}

model Reminder {
  id               String         @id @default(uuid())
  vehicleId        String
  vehicle          Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type             ReminderType
  dueDate          DateTime?
  dueMileage       Int?
  status           ReminderStatus @default(PENDING)
  note             String?
  recurrenceMonths Int?           @map("recurrence_months")
  notifiedStage1   Boolean        @default(false) @map("notified_stage1")
  notifiedStage2   Boolean        @default(false) @map("notified_stage2")
  notifiedStage3   Boolean        @default(false) @map("notified_stage3")
  deletedAt        DateTime?      @map("deleted_at")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Document {
  id              String         @id @default(uuid())
  vehicleId       String
  vehicle         Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  serviceRecordId String?        @map("service_record_id")
  serviceRecord   ServiceRecord? @relation(fields: [serviceRecordId], references: [id], onDelete: SetNull)
  expenseId       String?        @map("expense_id")
  expense         Expense?       @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  type            DocumentType
  label           String
  fileUrl         String
  fileSizeBytes   Int?           @map("file_size_bytes")
  deletedAt       DateTime?      @map("deleted_at")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([serviceRecordId])
  @@index([expenseId])
}

enum FuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
  PLUG_IN_HYBRID
  HYDROGEN
}

enum ServiceType {
  OIL_CHANGE
  ENGINE_OIL_CHANGE
  TRANSMISSION_OIL_CHANGE
  TIRE_ROTATION
  TIRE_CHANGE
  BRAKE_SERVICE
  BRAKE_DISCS
  BRAKE_PADS
  BRAKE_BANDS
  HANDBRAKE
  FILTER_CHANGE
  OIL_FILTER
  FUEL_FILTER
  TRANSMISSION_FILTER
  AIR_FILTER
  CABIN_FILTER
  INSPECTION
  MAIN_INSPECTION
  RE_INSPECTION
  TRANSMISSION_SERVICE
  COOLANT_FLUSH
  BATTERY_REPLACEMENT
  WINDSHIELD
  WINDSHIELD_REPAIR
  WINDSHIELD_REPLACEMENT
  OTHER
}

enum ExpenseCategory {
  FUEL
  SERVICE
  INSURANCE
  TAX
  PARKING
  TOLL
  REPAIR
  THRIF
  OTHER
}

enum ReminderType {
  OIL_CHANGE
  INSPECTION
  INSURANCE_RENEWAL
  TAX_DUE
  TIRE_CHANGE
  OTHER
}

enum ReminderStatus {
  PENDING
  DONE
  SNOOZED
}

model CarMake {
  id     Int        @id @default(autoincrement())
  name   String     @unique
  models CarModel[]

  @@map("car_makes")
}

model CarModel {
  id     Int     @id @default(autoincrement())
  makeId Int     @map("make_id")
  make   CarMake @relation(fields: [makeId], references: [id], onDelete: Cascade)
  name   String

  @@unique([makeId, name])
  @@map("car_models")
}

enum DocumentType {
  INSURANCE
  REGISTRATION
  INSPECTION_CERT
  WARRANTY
  RECEIPT
  OTHER
}

// ── Magic Link Auth ───────────────────────────────────────────────────────────

model MagicLinkToken {
  id        String    @id @default(uuid())
  email     String
  tokenHash String    @unique @map("token_hash")
  sessionId String    @unique @map("session_id")
  jwt       String?
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("magic_link_tokens")
}

// ── Audit Log ────────────────────────────────────────────────────────────────

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum AuditResource {
  VEHICLE
  SERVICE_RECORD
  EXPENSE
  MILEAGE_LOG
  REMINDER
  DOCUMENT
  WORK_ORDER
  ORGANIZATION
  TRIP_LOG
  USER
}

model AuditLog {
  id         String        @id @default(uuid())
  userId     String        @map("user_id")
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     AuditAction
  resource   AuditResource
  resourceId String        @map("resource_id")
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([userId])
  @@index([resource, resourceId])
  @@map("audit_logs")
}

// ── Phase 2: Multi-Tenant ────────────────────────────────────────────────────

enum AccountType {
  PERSONAL
  INDUSTRIAL
  WORKSHOP
}

enum OrgType {
  FLEET
  WORKSHOP
}

enum OrgRole {
  OWNER
  MANAGER
  DRIVER
  TECHNICIAN
  VIEWER
}

model Organization {
  id                 String               @id @default(uuid())
  name               String
  type               OrgType
  country            String               @default("IS")
  registrationNumber String?              @map("registration_number")
  suspendedAt        DateTime?            @map("suspended_at")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  members            OrganizationMember[]
  vehicles           Vehicle[]
  workOrders         WorkOrder[]          @relation("WorkshopOrg")
  costCenters        CostCenter[]
  invites            OrgInvite[]

  @@map("organizations")
}

model OrgInvite {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           OrgRole
  tokenHash      String       @unique @map("token_hash")
  expiresAt      DateTime     @map("expires_at")
  acceptedAt     DateTime?    @map("accepted_at")
  createdBy      String       @map("created_by")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@map("org_invites")
}

model OrganizationMember {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           OrgRole
  createdAt      DateTime     @default(now()) @map("created_at")

  @@unique([organizationId, userId])
  @@map("organization_members")
}

model WorkOrder {
  id             String       @id @default(uuid())
  vehicleId      String       @map("vehicle_id")
  vehicle        Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  workshopOrgId  String       @map("workshop_org_id")
  workshopOrg    Organization @relation("WorkshopOrg", fields: [workshopOrgId], references: [id])
  technicianId   String?      @map("technician_id")
  technician     User?        @relation("TechnicianWorkOrders", fields: [technicianId], references: [id])
  description    String
  completedAt    DateTime?    @map("completed_at")
  signedAt       DateTime?    @map("signed_at")
  cancelledAt    DateTime?    @map("cancelled_at")
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@map("work_orders")
}

model TripLog {
  id           String    @id @default(uuid())
  vehicleId    String    @map("vehicle_id")
  vehicle      Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverId     String    @map("driver_id")
  driver       User      @relation("DriverTripLogs", fields: [driverId], references: [id], onDelete: Cascade)
  startMileage Int       @map("start_mileage")
  endMileage   Int?      @map("end_mileage")
  date         DateTime
  purpose      String?
  note         String?
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("trip_logs")
}

model CostCenter {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  code           String?
  expenses       Expense[]
  createdAt      DateTime     @default(now()) @map("created_at")

  @@unique([organizationId, name])
  @@map("cost_centers")
}
